# ── Проект ────────────────────────────────────────────────────
# Скопируйте в .env: Copy-Item .env.example .env
# Запуск: .\scripts\start-project.ps1 -Name unf
# Выбор сервисов: -Services metadata,graph (шаблоны — глобально)
# ──────────────────────────────────────────────────────────────

PROJECT_NAME=unf

# ── Порты (PORT_BASE + смещение) ─────────────────────────────
CODE_METADATA_PORT=8500
CLOUD_PORT=8501
GRAPH_PORT=8506
NEO4J_BROWSER_PORT=8574
NEO4J_BOLT_PORT=8587

# ── Индексация CodeMetadata (опционально) ────────────────────
# Раскомментируйте для переопределения значений по умолчанию.
# INDEX_CODE=true
# INDEX_METADATA=true
# INDEX_HELP=true
# INDEX_BATCH_SIZE=25
# CHUNK_SIZE=1000

# ── Индексация CloudEmbeddings (опционально) ────────────────
# EMBEDDING_CONCURRENCY=10
# CLOUD_EMBEDDING_BATCH_SIZE=10
# CLOUD_CHUNK_SIZE=1000
# CLOUD_CHUNK_OVERLAP=100
# CLOUD_MAX_BATCH_SIZE=100
# AUTO_INDEX=true

# ── Индексация Graph (опционально) ──────────────────────────
# LLM графа — только GRAPH_OPENAI_API_BASE / GRAPH_OPENAI_API_KEY в корневом .env (общие OPENAI_* в compose не подставляются)
# Отдельный API эмбеддингов в корневом .env: OPENAI_EMBEDDING_API_BASE, OPENAI_EMBEDDING_API_KEY
# ENABLE_CODE_SEARCH=true
# ENABLE_BUSINESS_SEARCH=true
# CODE_SEARCH_MAX_FILE_SIZE=50000
# GRAPH_INDEX_BATCH_SIZE=50
# MAX_TOKENS_PER_BATCH=7500
# GRAPH_MCP_PORT=8006   # должен совпадать с правой частью ports graph_metadata в docker-compose
# MCP_USE_SSE=false
# GRAPH_METADATA_DEBUG=false

# ── Сброс векторного хранилища / кэша (проектные MCP) ───────
# true при старте контейнера очищает БД/кэш и запускает переиндексацию
# (долго и нагрузка на API эмбеддингов). После успешного прогона верните
# false или удалите строки — иначе сброс будет при каждом рестарте.
# CODE_METADATA_RESET_DATABASE=false
# CODE_METADATA_RESET_CACHE=false
# GRAPH_METADATA_RESET_DATABASE=false
