# ══════════════════════════════════════════════════════════════
# MCP-серверы для 1С — общая конфигурация
# ══════════════════════════════════════════════════════════════
# Скопируйте этот файл в .env и заполните значения:
#   Copy-Item .env.example .env
# ══════════════════════════════════════════════════════════════

# ── Лицензионные ключи (у каждого сервера свой) ──────────────

LICENSE_KEY_SYNTAX_CHECK=
LICENSE_KEY_HELP_SEARCH=
LICENSE_KEY_CODE_CHECKER=
LICENSE_KEY_SSL_SEARCH=
LICENSE_KEY_FORMS_SERVER=
LICENSE_KEY_CODE_METADATA=
LICENSE_KEY_GRAPH_METADATA=
LICENSE_KEY_TEMPLATES=
LICENSE_KEY_CLOUD_EMBEDDINGS=

# ── Токен 1С:Напарник (для CodeChecker) ──────────────────────

ONEC_AI_TOKEN=

# ── Embedding-модель (OpenRouter) ────────────────────────────
# Используется всеми серверами для семантического поиска.

OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=qwen/qwen3-embedding-8b

# ── Graph Metadata Search: endpoint LLM для графа и эмбеддинги ──
# LLM (search_metadata, answer_metadata_question):
# Без неё работают execute_metadata_cypher, get_metadata_prompt,
# business_search, search_code.
# Endpoint LLM для графа — задайте GRAPH_OPENAI_API_BASE и GRAPH_OPENAI_API_KEY (в контейнер передаются как OPENAI_API_BASE / OPENAI_API_KEY).
# GRAPH_OPENAI_API_BASE=https://api.openai.com/v1
# GRAPH_OPENAI_API_KEY=
# Или
# GRAPH_OPENAI_API_BASE=http://host.docker.internal:1234/v1
# GRAPH_OPENAI_API_KEY=lm-studio
GRAPH_LLM_MODEL=#

# Лимит ответа LLM для graph_metadata (search_metadata и т.д.). Не ставьте ниже 16:
# OPENAI_MAX_COMPLETION_TOKENS=2000

# Индексация graph_metadata (docker-compose подставляет в контейнер)
# AUTO_UPDATE_ON_STARTUP=true
# ASYNC_VECTOR_INDEXING=true

# Поиск в graph_metadata (docker-compose)
# ENABLE_CODE_SEARCH=true
# ENABLE_BUSINESS_SEARCH=true

# Отдельный URL/ключ только для эмбеддингов (если пусто — в projects/*/docker-compose подставляются OPENAI_API_BASE и OPENAI_API_KEY)
# Модель эмбеддингов: OPENAI_EMBEDDING_MODEL, иначе используется OPENAI_MODEL.
# OPENAI_EMBEDDING_API_BASE=
# OPENAI_EMBEDDING_API_KEY=
# OPENAI_EMBEDDING_MODEL=
# OPENAI_MODEL_IS_REASONING=   # true/false для «рассуждающих» LLM
#
# HTTP MCP внутри контейнера graph_metadata (порт публикации — GRAPH_PORT в projects/*/.env):
# GRAPH_MCP_HOST=0.0.0.0
# GRAPH_MCP_PORT=8006
# GRAPH_MCP_PATH=/mcp
# MCP_USE_SSE=false
# GRAPH_METADATA_DEBUG=false
#
# Локальные эмбеддинги CPU (sentence-transformers), если используете режим из документации образа:
# EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ── Платформа 1С ─────────────────────────────────────────────

PLATFORM_BIN_PATH=C:/Program Files/1cv8/8.3.25.1257/bin

# ── БСП ──────────────────────────────────────────────────────

SSL_VERSION=3.1.11

# ── Сброс векторного хранилища / кэша (глобальные MCP) ───────
# См. global/docker-compose.yml — help_search, ssl_search, template_search.
# true = полная очистка и переиндексация при старте. После прогона верните false.
# HELP_SEARCH_RESET_DATABASE=false
# HELP_SEARCH_RESET_CACHE=false
# SSL_SEARCH_RESET_DATABASE=false
# SSL_SEARCH_RESET_CACHE=false
# TEMPLATE_SEARCH_RESET_DATABASE=false
# TEMPLATE_SEARCH_RESET_CACHE=false
#
# Переменные ниже можно задать здесь или в projects/<имя>/.env (оба файла
# подключаются при start-project.ps1) — сервисы code_metadata / graph_metadata.
# CODE_METADATA_RESET_DATABASE=false
# CODE_METADATA_RESET_CACHE=false
# GRAPH_METADATA_RESET_DATABASE=false

# ── Neo4j (общий пароль для всех проектов) ───────────────────

NEO4J_PASSWORD=password123
