.env

# Каталог с API-ключами
API keys/

# Персистентные тома (индексы, кэш, данные Neo4j и т.п.)
# Явно: глобальный том и том каждого проекта — шаблон projects/*/volumes/ подхватывает
# новые проекты без правок .gitignore. **/volumes/ — любые другие каталоги volumes в репо.
global/volumes/
projects/*/volumes/
**/volumes/

# Выгрузки из Конфигуратора (большие, локальные)
**/data/report/*
**/data/src/*
!**/.gitkeep
